# ── Environment Configuration ──────────────────────────────────────────────
# Copy this file to .env and fill in your values

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── MongoDB Atlas (Free M0 Tier) ─────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Create free cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/leadflow?retryWrites=true&w=majority

# ── JWT Secrets (generate with: node -e "require('crypto').randomBytes(64).toString('hex') |clipboard") ──
JWT_ACCESS_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_ACCESS
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_REFRESH
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Encryption Key for sensitive fields (32 chars) ────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_32_CHARACTER_ENCRYPTION_KEY_HERE

# ── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
ADMIN_JWT_SECRET=CHANGE_ME_ADMIN_JWT_SECRET

# ── Frontend URL (for CORS) ────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5500

# ── Gmail (fallback - user settings override this) ───────────────────────────
# These are ONLY used as system fallback. Each user sets their own in Settings.
SYSTEM_GMAIL_USER=
SYSTEM_GMAIL_PASS=

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
